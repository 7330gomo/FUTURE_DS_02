select count(*) as Total_customers,

signup_date,
monthname(signup_date) as signup_month,
year(signup_date) as signup_year,
plan_type,
count(churn) OVER(PARTITION BY plan_type) churn_count_plans,
monthly_fee,
avg_weekly_usage_hours,
count(churn) OVER(PARTITION BY avg_weekly_usage_hours) churn__count_usage,
CASE 
    WHEN avg_weekly_usage_hours = 0 THEN 'No usage'
    WHEN avg_weekly_usage_hours > 0 AND avg_weekly_usage_hours <= 2 THEN 'Very low usage (0-2 hrs)'
    WHEN avg_weekly_usage_hours > 2 AND avg_weekly_usage_hours <= 5 THEN 'Low usage (2-5 hrs)'
    WHEN avg_weekly_usage_hours > 5 AND avg_weekly_usage_hours <= 10 THEN 'Moderate usage (5-10 hrs)'
    WHEN avg_weekly_usage_hours > 10 AND avg_weekly_usage_hours <= 15 THEN 'High usage (10-15 hrs)'
    WHEN avg_weekly_usage_hours > 15 AND avg_weekly_usage_hours <= 20 THEN 'Very high usage (15-20 hrs)'
    WHEN avg_weekly_usage_hours > 20 AND avg_weekly_usage_hours <= 25 THEN 'Power users (20-25 hrs)'
    WHEN avg_weekly_usage_hours > 25 THEN 'Extreme usage (25+ hrs)'
    ELSE 'Unknown'
END AS usage_category,
support_tickets,
count(churn) over(partition by support_tickets) AS churn_count_tickets,
CASE 
    WHEN support_tickets = 0 THEN '0 tickets'
    WHEN support_tickets = 1 THEN '1 ticket'
    WHEN support_tickets = 2 THEN '2 tickets'
    WHEN support_tickets = 3 THEN '3 tickets'
    WHEN support_tickets = 4 THEN '4 tickets'
    WHEN support_tickets = 5 THEN '5 tickets'
    WHEN support_tickets = 6 THEN '6 tickets'
    WHEN support_tickets = 7 THEN '7 tickets'
    WHEN support_tickets = 8 THEN '8 tickets'
    ELSE '9+ tickets'
END AS ticket_category,
payment_failures,
count(churn) over(partition by payment_failures) AS churn_count_paymentFailures,
CASE 
    WHEN payment_failures = 0 THEN 'No failures'
    WHEN payment_failures = 1 THEN '1 failure'
    WHEN payment_failures = 2 THEN '2 failures'
    WHEN payment_failures = 3 THEN '3 failures'
    WHEN payment_failures = 4 THEN '4 failures'
    WHEN payment_failures = 5 THEN '5 failures'
    WHEN payment_failures > 5 THEN '5+ failures'
    ELSE 'Unknown'
END AS payment_failure_category,
tenure_months,
CASE 
    WHEN tenure_months BETWEEN 0 AND 3 THEN '0-3 months (New users)'
    WHEN tenure_months BETWEEN 4 AND 6 THEN '4-6 months (Early stage)'
    WHEN tenure_months BETWEEN 7 AND 12 THEN '7-12 months (Developing users)'
    WHEN tenure_months BETWEEN 13 AND 24 THEN '13-24 months (Established users)'
    WHEN tenure_months BETWEEN 25 AND 36 THEN '25-36 months (Loyal users)'
    WHEN tenure_months > 36 THEN '36+ months (Long-term users)'
    ELSE 'Unknown'
END AS tenure_category,
last_login_days_ago,
CASE 
    WHEN last_login_days_ago = 0 THEN 'Active today'
    WHEN last_login_days_ago BETWEEN 1 AND 7 THEN 'Inactive (1-7 days)'
    WHEN last_login_days_ago BETWEEN 8 AND 14 THEN 'inactive (8-14 days)'
    WHEN last_login_days_ago BETWEEN 15 AND 30 THEN 'Inactive (15-30 days)'
    WHEN last_login_days_ago BETWEEN 31 AND 60 THEN 'Inactive (31-60 days)'
    WHEN last_login_days_ago > 60 THEN 'Churn risk (60+ days)'
    ELSE 'Unknown'
END AS login_recency_category,
churn,

SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END) AS churned_customers,

SUM(CASE WHEN churn = 'No' THEN 1 ELSE 0 END) AS retained_customers,
SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END)/COUNT(*)  AS churn_rate,
SUM(CASE WHEN churn = 'No' THEN 1 ELSE 0 END)/COUNT(*)  AS retention_rate


from customer.subscription.churn_analysis
group by signup_date,plan_type,monthly_fee,  avg_weekly_usage_hours, support_tickets, payment_failures, tenure_months, last_login_days_ago,churn ;




