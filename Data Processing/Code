---------CODE FOR CHURN RATE BY PLAN,SUPPORT TICKETS,PAYMENT FAILURES AND AVG WEEKLY USAGE

SELECT 
    plan_type,

    /* PLAN ANALYSIS */
    COUNT(*) AS total_customers,
     monthname(signup_date) AS signup_Month,
    SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END) AS churned,

    ROUND(
        SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 /
        SUM(SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END)) OVER (),
        2
    ) AS churn_percentage_by_plan,

    /* SUPPORT TICKET ANALYSIS */
    support_tickets,

    CASE 
        WHEN support_tickets = 0 THEN '0 tickets'
        WHEN support_tickets = 1 THEN '1 ticket'
        WHEN support_tickets = 2 THEN '2 tickets'
        WHEN support_tickets = 3 THEN '3 tickets'
        WHEN support_tickets = 4 THEN '4 tickets'
        WHEN support_tickets = 5 THEN '5 tickets'
        WHEN support_tickets = 6 THEN '6 tickets'
        WHEN support_tickets = 7 THEN '7 tickets'
        WHEN support_tickets = 8 THEN '8 tickets'
        ELSE '9+ tickets'
    END AS ticket_category,

    ROUND(
        SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 /
        SUM(SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END)) OVER (),
        2
    ) AS churn_percentage_by_ticket_category,

    /* PAYMENT FAILURE ANALYSIS */
    payment_failures,

    CASE
        WHEN payment_failures = 0 THEN 'No failures'
        WHEN payment_failures = 1 THEN '1 failure'
        WHEN payment_failures = 2 THEN '2 failures'
        WHEN payment_failures = 3 THEN '3 failures'
        WHEN payment_failures = 4 THEN '4 failures'
        WHEN payment_failures = 5 THEN '5 failures'
        WHEN payment_failures > 5 THEN '5+ failures'
        ELSE 'Unknown'
    END AS payment_failure_category,

    ROUND(
        SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 /
        SUM(SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END)) OVER (),
        2
    ) AS churn_percentage_by_payment_failures,

    /* USAGE ANALYSIS */
    usage_category,

    ROUND(
        SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END) * 100.0 /
        SUM(SUM(CASE WHEN churn = 'Yes' THEN 1 ELSE 0 END)) OVER (),
        2
    ) AS churn_percentage_by_usage_category

FROM (
    SELECT
        plan_type,
        support_tickets,
        payment_failures,
        churn,
         signup_date,

        CASE 
            WHEN avg_weekly_usage_hours = 0 THEN 'No usage'
            WHEN avg_weekly_usage_hours > 0 AND avg_weekly_usage_hours <= 2 THEN 'Very low usage (0-2 hrs)'
            WHEN avg_weekly_usage_hours > 2 AND avg_weekly_usage_hours <= 5 THEN 'Low usage (2-5 hrs)'
